# -----------------------------------------------------------------------------
# Pipeline outputs — never committed. Everything under these folders except the
# .gitkeep placeholder is generated by scripts/analyze_throw_cv.py or
# scripts/extract_keyframes.py.
# -----------------------------------------------------------------------------

# Input clips (user's own footage)
clips/*
!clips/.gitkeep

# Overlay videos
annotated/*
!annotated/.gitkeep

# Metrics JSON and per-event keyframe directories
metrics/*
!metrics/.gitkeep

# Ad-hoc keyframe extractions
keyframes/*
!keyframes/.gitkeep

# Stabilization intermediates
*.stabilized.mp4
*.stabilized.mov

# Trend log (accumulates per-session)
history.jsonl

# User's personal config — only the example is tracked
config.yaml

# The pre-merge staging subfolder (scheduled for deletion)
disc-golf-analyzer-public/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.pytest_cache/

# -----------------------------------------------------------------------------
# OS / editors
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
